@model WebApp.Models.Applicant.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
}
<h2>Профиль абитуриента</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

<form asp-action="Update" method="post">
    <div class="mb-3">
        <label class="form-label">ФИО</label>
        <input asp-for="FullName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Телефон</label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Дата рождения</label>
        <input asp-for="BirthDate" type="date" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>

<form asp-action="Create" method="post" class="mt-3">
    <input type="hidden" asp-for="FullName" />
    <input type="hidden" asp-for="Phone" />
    <input type="hidden" asp-for="BirthDate" />
    <button type="submit" class="btn btn-success">Создать профиль</button>
</form>
